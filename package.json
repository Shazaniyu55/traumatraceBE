{
  "name": "traumatrace-backend",
  "version": "0.1.0",
  "description": "TraumaTrace API — NestJS + TypeORM + Postgres + Firebase",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "seed": "ts-node -r tsconfig-paths/register src/modules/seed/seed.ts",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:show": "npm run typeorm migration:show -- -d ./src/configs/typeorm.config.ts",
    "migration:run": "npm run typeorm migration:run -- -d ./src/configs/typeorm.config.ts",
    "migration:generate": "npm run typeorm -- -d ./src/configs/typeorm.config.ts migration:generate ./src/migrations/$npm_config_name",
    "migration:create": "npm run typeorm -- migration:create ./src/migrations/$npm_config_name",
    "migration:revert": "npm run typeorm -- -d ./src/configs/typeorm.config.ts migration:revert"

  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "crypto-random-string": "^5.0.0",
    "firebase-admin": "^12.0.0",
    "joi": "^18.2.3",
    "multer": "^2.2.0",
    "nanoid": "^5.1.15",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "resend": "^6.14.0",
    "rxjs": "^7.8.1",
    "streamifier": "^0.1.1",
    "typeorm": "^0.3.20",
    "unique-string": "^3.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
